# Dispatch: call the specific ability function based on mob scoreboard
execute @s[scores={mob=1}] ~ ~ ~ function dna:ability_creeper
execute @s[scores={mob=2}] ~ ~ ~ function dna:ability_enderman
execute @s[scores={mob=3}] ~ ~ ~ function dna:ability_spider
execute @s[scores={mob=4}] ~ ~ ~ function dna:ability_skeleton
execute @s[scores={mob=5}] ~ ~ ~ function dna:ability_zombie
execute @s[scores={mob=6}] ~ ~ ~ function dna:ability_blaze
execute @s[scores={mob=7}] ~ ~ ~ function dna:ability_slime
execute @s[scores={mob=8}] ~ ~ ~ function dna:ability_phantom
